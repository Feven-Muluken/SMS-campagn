# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (MySQL default)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sms_campaign
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql
# Optional: fail fast if MySQL is unreachable (ms). Pool acquire timeout also caps how long a request waits for a DB connection.
# DB_CONNECT_TIMEOUT_MS=15000
# DB_POOL_MAX=10
# DB_POOL_ACQUIRE_MS=60000
# Set true to let Sequelize alter tables (use carefully in production). New columns are also added on startup via ensureDbColumns().
DB_SYNC_ALTER=false

# JWT
JWT_SECRET=change-me

# Africa's Talking
AT_USERNAME=your_sandbox_or_live_username
AT_API_KEY=your_api_key
AT_SENDER_ID=

# Phone parsing (libphonenumber-js): use ISO region and/or calling code for national numbers
# DEFAULT_PHONE_REGION=ET
DEFAULT_PHONE_COUNTRY_CODE=251

# Webhooks (configure in Africa's Talking dashboard)
# Inbound SMS → POST https://your-api.example.com/sms/inbound
# Delivery reports → POST https://your-api.example.com/sms/delivery-report
# Optional shared secret (header x-at-webhook-secret or ?secret=)
AT_WEBHOOK_SECRET=

# Campaign scheduler
CAMPAIGN_SCHEDULER_ENABLED=true
CAMPAIGN_SCHEDULER_INTERVAL_MS=60000
CAMPAIGN_SENDER_ID=

# Appointment SMS scheduler
APPT_SCHEDULER_ENABLED=true
APPT_SCHEDULER_INTERVAL_MS=60000
APPT_TIMEZONE=UTC

# Live GPS for geo SMS (mobile app posts to POST /sms/live-location/ping)
# Same secret must be sent as header: X-Live-Location-Key: <value>
LIVE_LOCATION_INGEST_KEY=change-me-long-random-string
# Only pings newer than this are used for geo targeting (default 15)
# LIVE_LOCATION_MAX_AGE_MINUTES=15
